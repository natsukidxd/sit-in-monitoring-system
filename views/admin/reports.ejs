<section class="py-3 py-lg-4">
  <div class="container-fluid px-lg-3">
    <div class="panel-card mb-3">
      <div class="panel-header">Sit-in Reports</div>
      <div class="panel-body">
        <form action="/admin/reports" method="GET" class="row g-3">
          <div class="col-md-4">
            <label class="form-label fw-semibold">Search Student</label>
            <input
              type="text"
              name="search"
              class="form-control"
              value="<%= filters.search %>"
              placeholder="Name or ID Number"
            />
          </div>

          <div class="col-md-2">
            <label class="form-label fw-semibold">Purpose</label>
            <select name="purpose" class="form-select">
              <option value="" selected>All</option>
              <option value="C#">C#</option>
              <option value="C">C</option>
              <option value="Java">Java</option>
              <option value="ASP.NET">ASP.NET</option>
              <option value="PHP">PHP</option>
              <option value="Python">Python</option>
              <option value="JavaScript">JavaScript</option>
              <option value="TypeScript">TypeScript</option>
              <option value="Networking">Networking</option>
            </select>
          </div>

          <div class="col-md-2">
            <label class="form-label fw-semibold">Lab Room</label>
            <select name="lab_room" class="form-select">
              <option value="">All</option>
              <option value="524" <%= filters.lab_room === '524' ? 'selected' : '' %>>524</option>
              <option value="526" <%= filters.lab_room === '526' ? 'selected' : '' %>>526</option>
              <option value="528" <%= filters.lab_room === '528' ? 'selected' : '' %>>528</option>
              <option value="530" <%= filters.lab_room === '530' ? 'selected' : '' %>>530</option>
              <option value="542" <%= filters.lab_room === '542' ? 'selected' : '' %>>542</option>
              <option value="Mac" <%= filters.lab_room === 'Mac' ? 'selected' : '' %>>Mac</option>
            </select>
          </div>

          <div class="col-md-2">
            <label class="form-label fw-semibold">Date From</label>
            <input type="date" name="date_from" class="form-control" value="<%= filters.date_from %>" />
          </div>

          <div class="col-md-2">
            <label class="form-label fw-semibold">Date To</label>
            <input type="date" name="date_to" class="form-control" value="<%= filters.date_to %>" />
          </div>

          <div class="col-12 d-flex gap-2">
            <button class="btn btn-primary" type="submit">Apply Filters</button>
            <a class="btn btn-outline-secondary" href="/admin/reports">Reset</a>
            <a class="btn btn-success ms-auto" href="/admin/reports/export?<%= exportQuery %>">
              Export CSV
            </a>
            <a class="btn btn-danger" href="/admin/reports/export/pdf?<%= exportQuery %>">
              Export PDF
            </a>
          </div>
        </form>
      </div>
    </div>

    <div class="panel-card">
      <div class="panel-header">Report Results</div>
      <div class="panel-body table-responsive">
        <table class="table table-bordered align-middle mb-0">
          <thead>
            <tr>
              <th>ID Number</th>
              <th>Name</th>
              <th>Course</th>
              <th>Year</th>
              <th>Purpose</th>
              <th>Time In</th>
              <th>Time Out</th>
              <th>Date</th>
            </tr>
          </thead>
          <tbody>
            <% if (!records.length) { %>
            <tr>
              <td colspan="8" class="text-center py-4 text-muted">No sit-in records found for the selected filters.</td>
            </tr>
            <% } %>

            <% records.forEach((item) => { %>
            <tr>
              <td><%= item.id_number %></td>
              <td><%= item.first_name %> <%= item.last_name %></td>
              <td><%= item.course || '-' %></td>
              <td><%= item.course_level || '-' %></td>
              <td><%= item.purpose %></td>
              <td><%= item.time_in ? new Date(item.time_in).toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit', second: '2-digit' }) : '-' %></td>
              <td><%= item.time_out ? new Date(item.time_out).toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit', second: '2-digit' }) : '-' %></td>
              <td><%= item.time_in ? new Date(item.time_in).toLocaleDateString() : '-' %></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>
