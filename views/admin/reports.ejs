<section class="py-3 py-lg-4">
  <div class="container-fluid px-lg-3">
    <div class="panel-card mb-3">
      <div class="panel-header">Sit-in Reports</div>
      <div class="panel-body">
        <form action="/admin/reports" method="GET" class="row g-3">
          <div class="col-md-4">
            <label class="form-label fw-semibold">Search Student</label>
            <input
              type="text"
              name="search"
              class="form-control"
              value="<%= filters.search %>"
              placeholder="Name or ID Number"
            />
          </div>

          <div class="col-md-2">
            <label class="form-label fw-semibold">Status</label>
            <select name="status" class="form-select">
              <option value="">All</option>
              <option value="Active" <%= filters.status === 'Active' ? 'selected' : '' %>>Active</option>
              <option value="Completed" <%= filters.status === 'Completed' ? 'selected' : '' %>>Completed</option>
            </select>
          </div>

          <div class="col-md-2">
            <label class="form-label fw-semibold">Lab Room</label>
            <select name="lab_room" class="form-select">
              <option value="">All</option>
              <% (labRooms || []).forEach((lab) => { %>
              <option value="<%= lab %>" <%= filters.lab_room === lab ? 'selected' : '' %>><%= lab %></option>
              <% }) %>
            </select>
          </div>

          <div class="col-md-2">
            <label class="form-label fw-semibold">Date From</label>
            <input type="date" name="date_from" class="form-control" value="<%= filters.date_from %>" />
          </div>

          <div class="col-md-2">
            <label class="form-label fw-semibold">Date To</label>
            <input type="date" name="date_to" class="form-control" value="<%= filters.date_to %>" />
          </div>

          <div class="col-12 d-flex gap-2">
            <button class="btn btn-primary" type="submit">Apply Filters</button>
            <a class="btn btn-outline-secondary" href="/admin/reports">Reset</a>
            <a class="btn btn-success ms-auto" href="/admin/reports/export?<%= exportQuery %>">
              Export CSV
            </a>
            <a class="btn btn-danger" href="/admin/reports/export/pdf?<%= exportQuery %>">
              Export PDF
            </a>
          </div>
        </form>
      </div>
    </div>

    <div class="row g-3 mb-3">
      <div class="col-md-3">
        <div class="summary-card">
          <span>Total Records</span>
          <strong><%= summary.totalRecords %></strong>
        </div>
      </div>
      <div class="col-md-3">
        <div class="summary-card">
          <span>Active</span>
          <strong><%= summary.activeRecords %></strong>
        </div>
      </div>
      <div class="col-md-3">
        <div class="summary-card">
          <span>Completed</span>
          <strong><%= summary.completedRecords %></strong>
        </div>
      </div>
      <div class="col-md-3">
        <div class="summary-card">
          <span>Unique Students</span>
          <strong><%= summary.uniqueStudents %></strong>
        </div>
      </div>
    </div>

    <div class="panel-card">
      <div class="panel-header">Report Results</div>
      <div class="panel-body table-responsive">
        <table class="table table-bordered align-middle mb-0">
          <thead>
            <tr>
              <th>ID Number</th>
              <th>Name</th>
              <th>Course</th>
              <th>Year</th>
              <th>Lab</th>
              <th>Purpose</th>
              <th>Status</th>
              <th>Time In</th>
              <th>Time Out</th>
            </tr>
          </thead>
          <tbody>
            <% if (!records.length) { %>
            <tr>
              <td colspan="9" class="text-center py-4 text-muted">No sit-in records found for the selected filters.</td>
            </tr>
            <% } %>

            <% records.forEach((item) => { %>
            <tr>
              <td><%= item.id_number %></td>
              <td><%= item.first_name %> <%= item.last_name %></td>
              <td><%= item.course || '-' %></td>
              <td><%= item.course_level || '-' %></td>
              <td><%= item.lab_room %></td>
              <td><%= item.purpose %></td>
              <td>
                <span class="badge <%= item.status === 'Active' ? 'bg-success' : 'bg-secondary' %>"><%= item.status %></span>
              </td>
              <td><%= item.time_in ? new Date(item.time_in).toLocaleString() : '-' %></td>
              <td><%= item.time_out ? new Date(item.time_out).toLocaleString() : '-' %></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>
