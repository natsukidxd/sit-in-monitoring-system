<section class="py-3 py-lg-4">
  <div class="container-fluid px-lg-3">
    <div class="row g-3">
      <div class="col-xl-3">
        <div class="panel-card h-100">
          <div class="panel-header">Admin Information</div>
          <div class="panel-body text-center">
            <img
              src="/profile-image/<%= admin?.image_url || 'default.png' %>"
              alt="Admin Profile"
              class="img-fluid rounded-circle border shadow-sm"
              style="width: 160px; height: 160px; object-fit: cover;"
            />

            <div class="student-details text-start mt-3">
              <p>
                <i class="bi bi-person-fill"></i>
                <strong>Name:</strong>
                <%= admin?.first_name || '' %>
                <%= admin?.middle_name || '' %>
                <%= admin?.last_name || '' %>
              </p>
              <p>
                <i class="bi bi-hash"></i>
                <strong>ID Number:</strong>
                <%= admin?.id_number || '-' %>
              </p>
              <p>
                <i class="bi bi-shield-check"></i>
                <strong>Role:</strong>
                <%= admin?.role || 'admin' %>
              </p>
            </div>
          </div>
        </div>
      </div>

      <div class="col-xl-9">
        <div class="panel-card h-100">
          <div class="panel-header d-flex align-items-center justify-content-between">
            <span>Laboratory Usage by Course</span>
            <span class="text small"><%= stats.totalCoursesUsingLab %> courses</span>
          </div>
          <div class="panel-body">
            <% if (!courseUsage.length) { %>
            <div class="alert alert-secondary mb-0">
              No sit-in records yet. Course usage chart will appear once students start using the lab.
            </div>
            <% } else { %>
            <div class="row g-3">
              <div class="col-lg-6">
                <canvas id="courseUsageChart" height="260"></canvas>
              </div>
              <div class="col-lg-6">
                <div class="table-responsive">
                  <table class="table table-bordered align-middle mb-0">
                    <thead>
                      <tr>
                        <th>Course</th>
                        <th>Sessions</th>
                        <th>Share</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% courseUsage.forEach(item => { %>
                      <tr>
                        <td><%= item.course %></td>
                        <td><%= item.usageCount %></td>
                        <td><%= item.percent %>%</td>
                      </tr>
                      <% }) %>
                    </tbody>
                  </table>
                </div>
              </div>
            </div>
            <% } %>
          </div>
        </div>
      </div>
    </div>

    <div class="row g-3 mt-1">
      <div class="col-md-3">
        <div class="summary-card">
          <span>Total Students</span>
          <strong><%= stats.totalStudents %></strong>
        </div>
      </div>

      <div class="col-md-3">
        <div class="summary-card">
          <span>Active Sit-ins</span>
          <strong><%= stats.activeSitins %></strong>
        </div>
      </div>

      <div class="col-md-3">
        <div class="summary-card">
          <span>Utilization Rate</span>
          <strong><%= stats.utilizationRate %>%</strong>
        </div>
      </div>

      <div class="col-md-3">
        <div class="summary-card">
          <span>Courses Using Lab</span>
          <strong><%= stats.totalCoursesUsingLab %></strong>
        </div>
      </div>
    </div>

    <div class="row g-3 mt-1">
      <div class="col-md-3">
        <div class="summary-card">
          <span>Completed Sit-ins</span>
          <strong><%= stats.completedSitins %></strong>
        </div>
      </div>

      <div class="col-md-3">
        <div class="summary-card">
          <span>Today's Sit-ins</span>
          <strong><%= stats.todaySitins %></strong>
        </div>
      </div>

      <div class="col-md-3">
        <div class="summary-card">
          <span>This Week Sit-ins</span>
          <strong><%= stats.thisWeekSitins %></strong>
        </div>
      </div>

      <div class="col-md-3">
        <div class="summary-card">
          <span>Labs Used</span>
          <strong><%= stats.uniqueLabsUsed %></strong>
        </div>
      </div>
    </div>

    <div class="row g-3 mt-1">
      <div class="col-md-4">
        <div class="summary-card">
          <span>Pending Reservations</span>
          <strong><%= stats.pendingReservations %></strong>
        </div>
      </div>

      <div class="col-md-4">
        <div class="summary-card">
          <span>Total Reservations</span>
          <strong><%= stats.totalReservations %></strong>
        </div>
      </div>

      <div class="col-md-4">
        <div class="summary-card">
          <span>Total Admins</span>
          <strong><%= stats.totalAdmins %></strong>
        </div>
      </div>
    </div>

    <div class="row g-3 mt-3">
      <div class="col-xl-6">
        <div class="panel-card h-100">
          <div class="panel-header">Recent Sit-in Records</div>
          <div class="panel-body table-responsive">
            <table class="table table-bordered align-middle mb-0">
              <thead>
                <tr>
                  <th>ID Number</th>
                  <th>Name</th>
                  <th>Lab</th>
                  <th>Purpose</th>
                  <th>Status</th>
                  <th>Time In</th>
                  <th>Time Out</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody>
                <% if (!recentRecords.length) { %>
                <tr>
                  <td colspan="8" class="text-center py-4 text-muted">
                    No records found.
                  </td>
                </tr>
                <% } %>

                <% recentRecords.forEach(record => { %>
                <tr>
                  <td><%= record.id_number %></td>
                  <td><%= record.first_name %> <%= record.last_name %></td>
                  <td><%= record.lab_room %></td>
                  <td><%= record.purpose %></td>
                  <td>
                    <span
                      class="badge <%= record.status === 'Active' ? 'bg-success' : 'bg-secondary' %>"
                    >
                      <%= record.status %>
                    </span>
                  </td>
                  <td>
                    <%= record.time_in ? new Date(record.time_in).toLocaleString() : '-' %>
                  </td>
                  <td>
                    <%= record.time_out ? new Date(record.time_out).toLocaleString() : '-' %>
                  </td>
                  <td>
                    <% if (record.status === 'Active') { %>
                    <form
                      action="/admin/records/<%= record.id %>/timeout"
                      method="POST"
                    >
                      <button class="btn btn-sm btn-danger" type="submit">
                        Force Time-out
                      </button>
                    </form>
                    <% } else { %>
                    <span class="text-muted small">No action</span>
                    <% } %>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <div class="col-xl-6">
        <div class="panel-card h-100">
          <div class="panel-header">Pending Reservations</div>
          <div class="panel-body table-responsive">
            <table class="table table-bordered align-middle mb-0">
              <thead>
                <tr>
                  <th>ID Number</th>
                  <th>Name</th>
                  <th>Lab</th>
                  <th>Purpose</th>
                  <th>Schedule</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody>
                <% if (!pendingReservations.length) { %>
                <tr>
                  <td colspan="6" class="text-center py-4 text-muted">
                    No pending reservations.
                  </td>
                </tr>
                <% } %>

                <% pendingReservations.forEach(item => { %>
                <tr>
                  <td><%= item.id_number %></td>
                  <td><%= item.first_name %> <%= item.last_name %></td>
                  <td><%= item.lab_room %></td>
                  <td><%= item.purpose %></td>
                  <td>
                    <%= item.reservation_time ? new Date(item.reservation_time).toLocaleString() : '-' %>
                  </td>
                  <td class="d-flex gap-2">
                    <form
                      action="/admin/reservations/<%= item.id %>/approve"
                      method="POST"
                    >
                      <button class="btn btn-sm btn-success" type="submit">
                        Approve
                      </button>
                    </form>
                    <form
                      action="/admin/reservations/<%= item.id %>/reject"
                      method="POST"
                    >
                      <button class="btn btn-sm btn-outline-danger" type="submit">
                        Reject
                      </button>
                    </form>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

    <div class="row g-3 mt-1">
      <div class="col-xl-12">
        <div class="panel-card">
          <div class="panel-header">Latest Students</div>
          <div class="panel-body table-responsive">
            <table class="table table-bordered align-middle mb-0">
              <thead>
                <tr>
                  <th>ID Number</th>
                  <th>Name</th>
                  <th>Course</th>
                  <th>Year</th>
                  <th>Used Sessions</th>
                </tr>
              </thead>
              <tbody>
                <% if (!users.length) { %>
                <tr>
                  <td colspan="5" class="text-center py-4 text-muted">
                    No students found.
                  </td>
                </tr>
                <% } %>

                <% users.forEach(user => { %>
                <tr>
                  <td><%= user.id_number %></td>
                  <td><%= user.first_name %> <%= user.last_name %></td>
                  <td><%= user.course %></td>
                  <td><%= user.course_level %></td>
                  <td><%= user.used_sessions %></td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<% if (courseUsage && courseUsage.length) { %>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
<script type="application/json" id="courseUsageChartData">
  <%- JSON.stringify({
    labels: courseUsage.map((item) => item.course),
    values: courseUsage.map((item) => item.usageCount)
  }) %>
</script>
<script>
  (function () {
    const canvas = document.getElementById("courseUsageChart");
    const dataEl = document.getElementById("courseUsageChartData");
    if (!canvas || !dataEl) return;

    let parsed;
    try {
      parsed = JSON.parse(dataEl.textContent || "{}");
    } catch (e) {
      return;
    }

    const labels = Array.isArray(parsed.labels) ? parsed.labels : [];
    const values = Array.isArray(parsed.values) ? parsed.values : [];
    if (!labels.length || !values.length) return;

    const colors = [
      "#124d99",
      "#1e57a2",
      "#2f6fc2",
      "#3b82f6",
      "#60a5fa",
      "#93c5fd",
      "#f59e0b",
      "#10b981",
      "#ef4444",
      "#8b5cf6",
    ];

    new Chart(canvas, {
      type: "pie",
      data: {
        labels,
        datasets: [
          {
            data: values,
            backgroundColor: labels.map((_, index) => colors[index % colors.length]),
            borderColor: "#ffffff",
            borderWidth: 2,
          },
        ],
      },
      options: {
        responsive: true,
        plugins: {
          legend: { position: "bottom" },
        },
      },
    });
  })();
</script>
<% } %>
