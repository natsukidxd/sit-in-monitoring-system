<section class="py-3 py-lg-4">
  <div class="container-fluid px-lg-3">
    <% 
      var purposeGraphSafe = purposeGraph || { labels: ["C#","C","Java","ASP.NET","PHP","Python","JavaScript","TypeScript","Networking"], counts: [0,0,0,0,0,0,0,0,0], yMax: 10 };
      var labGraphSafe = labGraph || { labels: ["524","526","528","530","542","Mac"], counts: [0,0,0,0,0,0], yMax: 10 };
      var purposeYMax = Number(purposeGraphSafe.yMax || 10) || 10;
      var labYMax = Number(labGraphSafe.yMax || 10) || 10;
    %>

    <div class="row g-3 mb-3">
      <div class="col-xl-6">
        <div class="panel-card h-100">
          <div class="panel-header">Purpose (Active)</div>
          <div class="panel-body">
            <div class="d-flex">
              <div class="d-flex flex-column justify-content-between text-muted small me-2" style="height: 240px; min-width: 36px;">
                <span><%= purposeYMax %></span>
                <span><%= Math.round(purposeYMax * 0.75) %></span>
                <span><%= Math.round(purposeYMax * 0.5) %></span>
                <span><%= Math.round(purposeYMax * 0.25) %></span>
                <span>0</span>
              </div>
              <div class="flex-grow-1">
                <div class="d-flex align-items-end gap-2" style="height: 240px; border-left: 1px solid #dee2e6; border-bottom: 1px solid #dee2e6; padding: 10px 10px 0;">
                  <% (purposeGraphSafe.labels || []).forEach(function(label, idx){ 
                      var count = Number((purposeGraphSafe.counts || [])[idx] || 0);
                      var heightPct = purposeYMax ? Math.max((count / purposeYMax) * 100, 0) : 0;
                  %>
                    <div class="d-flex flex-column align-items-center justify-content-end" style="flex: 1; min-width: 36px;">
                      <div class="text-muted small" style="font-size: 0.72rem; line-height: 1;"><%= count %></div>
                      <div class="bg-primary" style="width: 100%; max-width: 34px; height: <%= heightPct %>%; min-height: 2px; border-radius: 6px 6px 0 0;"></div>
                      <div class="text-muted small mt-1" style="font-size: 0.72rem; width: 56px; text-align: center; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title="<%= label %>"><%= label %></div>
                    </div>
                  <% }) %>
                </div>
              </div>
            </div>
            <div class="text-muted small mt-2">X-axis: Purpose • Y-axis: No. of students</div>
          </div>
        </div>
      </div>

      <div class="col-xl-6">
        <div class="panel-card h-100">
          <div class="panel-header">Laboratory (Active)</div>
          <div class="panel-body">
            <div class="d-flex">
              <div class="d-flex flex-column justify-content-between text-muted small me-2" style="height: 240px; min-width: 36px;">
                <span><%= labYMax %></span>
                <span><%= Math.round(labYMax * 0.75) %></span>
                <span><%= Math.round(labYMax * 0.5) %></span>
                <span><%= Math.round(labYMax * 0.25) %></span>
                <span>0</span>
              </div>
              <div class="flex-grow-1">
                <div class="d-flex align-items-end gap-2" style="height: 240px; border-left: 1px solid #dee2e6; border-bottom: 1px solid #dee2e6; padding: 10px 10px 0;">
                  <% (labGraphSafe.labels || []).forEach(function(label, idx){ 
                      var count = Number((labGraphSafe.counts || [])[idx] || 0);
                      var heightPct = labYMax ? Math.max((count / labYMax) * 100, 0) : 0;
                  %>
                    <div class="d-flex flex-column align-items-center justify-content-end" style="flex: 1; min-width: 36px;">
                      <div class="text-muted small" style="font-size: 0.72rem; line-height: 1;"><%= count %></div>
                      <div class="bg-success" style="width: 100%; max-width: 34px; height: <%= heightPct %>%; min-height: 2px; border-radius: 6px 6px 0 0;"></div>
                      <div class="text-muted small mt-1" style="font-size: 0.72rem; width: 56px; text-align: center; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title="<%= label %>"><%= label %></div>
                    </div>
                  <% }) %>
                </div>
              </div>
            </div>
            <div class="text-muted small mt-2">X-axis: Laboratory • Y-axis: No. of students</div>
          </div>
        </div>
      </div>
    </div>

    <div class="panel-card">
      <div class="panel-header">Active Sit-ins</div>
      <div class="panel-body table-responsive">
        <table class="table table-bordered align-middle mb-0">
          <thead>
            <tr>
              <th class="text-nowrap">Sit ID Number</th>
              <th class="text-nowrap">ID Number</th>
              <th>Name</th>
              <th>Purpose</th>
              <th class="text-nowrap">Laboratory</th>
              <th class="text-nowrap">PC</th>
              <th class="text-nowrap">Session</th>
              <th class="text-nowrap">Status</th>
              <th class="text-nowrap">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (!results || !results.length) { %>
              <tr>
                <td colspan="9" class="text-center py-4 text-muted">
                  No active sit-in sessions found.
                </td>
              </tr>
            <% } %>

            <% (results || []).forEach(row => { %>
              <tr>
                <td><%= row.sitin_id %></td>
                <td><%= row.id_number %></td>
                <td><%= row.first_name %> <%= row.last_name %></td>
                <td><%= row.purpose %></td>
                <td><%= row.lab_room %></td>
                <td><%= row.pc_number || '-' %></td>
                <td>
                  <% if (row.time_in) { %>
                    <%= new Date(row.time_in).toLocaleString() %>
                  <% } else { %>
                    -
                  <% } %>
                </td>
                <td>
                  <span class="badge <%= String(row.status) === 'Active' ? 'bg-success' : 'bg-secondary' %>">
                    <%= row.status || '-' %>
                  </span>
                </td>
                <td>
                  <form action="/admin/student-sitin/time-out" method="POST" class="m-0">
                    <input type="hidden" name="student_id" value="<%= row.user_id %>" />
                    <input type="hidden" name="returnTo" value="/admin/student-sitin?page=<%= page || 1 %>" />
                    <button class="btn btn-sm btn-danger" type="submit">
                      Time-out
                    </button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <div class="panel-footer p-3">
        <div class="d-flex align-items-center justify-content-between">
          <div class="text-muted small">
            Page <%= page || 1 %> of <%= totalPages || 1 %> • <%= total || 0 %> total
          </div>
          <nav aria-label="Active sit-ins pages">
            <ul class="pagination mb-0">
              <li class="page-item <%= (page || 1) <= 1 ? 'disabled' : '' %>">
                <a class="page-link" href="/admin/student-sitin?page=<%= Math.max((page || 1) - 1, 1) %>">Previous</a>
              </li>
              <% 
                var p = page || 1;
                var tp = totalPages || 1;
                var windowSize = 3;
                var start = Math.max(1, p - windowSize);
                var end = Math.min(tp, p + windowSize);
                for (var i = start; i <= end; i++) { 
              %>
                <li class="page-item <%= i === p ? 'active' : '' %>">
                  <a class="page-link" href="/admin/student-sitin?page=<%= i %>"><%= i %></a>
                </li>
              <% } %>
              <li class="page-item <%= (page || 1) >= (totalPages || 1) ? 'disabled' : '' %>">
                <a class="page-link" href="/admin/student-sitin?page=<%= Math.min((page || 1) + 1, (totalPages || 1)) %>">Next</a>
              </li>
            </ul>
          </nav>
        </div>
      </div>
    </div>
  </div>
</section>
