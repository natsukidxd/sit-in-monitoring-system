<section class="py-4">
  <div class="container-fluid px-lg-4">
    <div class="history-card">
      <h1 class="text-center fw-bold mb-4">History Information</h1>
      <div class="table-responsive">
        <table class="table history-table align-middle mb-0">
          <thead>
            <tr>
              <th>ID Number</th>
              <th>Name</th>
              <th>Sit Purpose</th>
              <th>Laboratory</th>
              <th>Login</th>
              <th>Logout</th>
              <th>Date</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody>
            <% if (records.length === 0) { %>
              <tr>
                <td colspan="8" class="text-center py-4">No history found.</td>
              </tr>
            <% } %>
            <% records.forEach(record => { %>
              <tr>
                <td><%= currentUser.id_number %></td>
                <td><%= currentUser.first_name || currentUser.name.split(' ')[0] %> <%= currentUser.last_name || '' %></td>
                <td><%= record.purpose %></td>
                <td><%= record.lab_room %></td>
                <td><%= record.time_in || '-' %></td>
                <td><%= record.time_out || '-' %></td>
                <td><%= (record.time_in || '').split(' ')[0] || '-' %></td>
                <td>
                  <% if (record.status === 'Active') { %>
                    <form action="/dashboard/time-out/<%= record.id %>" method="POST">
                      <button class="btn btn-success btn-sm">Time Out</button>
                    </form>
                  <% } else { %>
                    <% if (record.feedback_id) { %>
                      <button class="btn btn-outline-secondary btn-sm" type="button" data-bs-toggle="modal" data-bs-target="#feedbackViewModal-<%= record.id %>">
                        View Feedback
                      </button>
                    <% } else { %>
                      <button class="btn btn-primary btn-sm" type="button" data-bs-toggle="modal" data-bs-target="#feedbackModal-<%= record.id %>">
                        Feedback
                      </button>
                    <% } %>
                  <% } %>
                </td>
              </tr>

              <% if (record.status !== 'Active' && !record.feedback_id) { %>
                <div class="modal fade" id="feedbackModal-<%= record.id %>" tabindex="-1" aria-hidden="true">
                  <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content" style="border-radius: 14px; overflow: hidden;">
                      <div class="modal-header" style="background: linear-gradient(90deg, #124d99, #1e57a2);">
                        <h5 class="modal-title text-white fw-bold mb-0">Sit-in Feedback</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                      </div>
                      <form action="/dashboard/feedback/<%= record.id %>" method="POST">
                        <div class="modal-body">
                          <div class="mb-2 small text-muted">
                            Lab: <strong><%= record.lab_room %></strong> • Date: <strong><%= (record.time_in || '').split(' ')[0] || '-' %></strong>
                          </div>

                          <div class="mb-3">
                            <label class="form-label fw-semibold">Rating</label>
                            <select name="rating" class="form-select" required>
                              <option value="" selected disabled>Select rating</option>
                              <option value="5">5 - Excellent</option>
                              <option value="4">4 - Good</option>
                              <option value="3">3 - Okay</option>
                              <option value="2">2 - Poor</option>
                              <option value="1">1 - Very Poor</option>
                            </select>
                          </div>

                          <div class="mb-0">
                            <label class="form-label fw-semibold">Comments</label>
                            <textarea name="comments" class="form-control" rows="4" placeholder="Share your experience..."></textarea>
                          </div>
                        </div>
                        <div class="modal-footer">
                          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                          <button type="submit" class="btn btn-primary">Submit Feedback</button>
                        </div>
                      </form>
                    </div>
                  </div>
                </div>
              <% } %>

              <% if (record.status !== 'Active' && record.feedback_id) { %>
                <div class="modal fade" id="feedbackViewModal-<%= record.id %>" tabindex="-1" aria-hidden="true">
                  <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content" style="border-radius: 14px; overflow: hidden;">
                      <div class="modal-header" style="background: linear-gradient(90deg, #124d99, #1e57a2);">
                        <h5 class="modal-title text-white fw-bold mb-0">Your Feedback</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                      </div>
                      <div class="modal-body">
                        <div class="mb-2 small text-muted">
                          Submitted: <strong><%= record.feedback_created_at ? new Date(record.feedback_created_at).toLocaleString() : '-' %></strong>
                        </div>
                        <div class="mb-3">
                          <div class="fw-semibold">Rating</div>
                          <div><%= record.feedback_rating %> / 5</div>
                        </div>
                        <div>
                          <div class="fw-semibold">Comments</div>
                          <div class="text-muted"><%= record.feedback_comments || '—' %></div>
                        </div>
                      </div>
                      <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Close</button>
                      </div>
                    </div>
                  </div>
                </div>
              <% } %>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>
