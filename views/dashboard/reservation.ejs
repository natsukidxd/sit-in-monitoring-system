<section class="py-4">
  <div class="container">
    <div class="reservation-card mx-auto">
      <h2 class="text-center fw-bold mb-4">Reservation</h2>
      <form action="/dashboard/reservation" method="POST" class="row g-3 align-items-end">
        <div class="col-md-3"><label class="form-label">ID Number:</label></div>
        <div class="col-md-9"><input class="form-control reservation-readonly" value="<%= user.id_number %>" readonly></div>

        <div class="col-md-3"><label class="form-label">Student Name:</label></div>
        <div class="col-md-9"><input class="form-control reservation-readonly" value="<%= user.first_name %> <%= user.middle_name %> <%= user.last_name %>" readonly></div>

        <div class="col-md-3"><label class="form-label">Purpose:</label></div>
        <div class="col-md-9">
          <select name="purpose" class="form-select" required>
            <option value="" selected disabled>Select purpose</option>
            <option value="C#">C#</option>
            <option value="C">C</option>
            <option value="Java">Java</option>
            <option value="ASP.NET">ASP.NET</option>
            <option value="PHP">PHP</option>
            <option value="Python">Python</option>
            <option value="JavaScript">JavaScript</option>
            <option value="TypeScript">TypeScript</option>
            <option value="Networking">Networking</option>
          </select>
        </div>

        <div class="col-md-3"><label class="form-label">Lab:</label></div>
        <div class="col-md-9">
          <select name="lab_room" id="lab_room_select" class="form-select" required>
            <option value="" selected disabled>Select laboratory</option>
            <option value="524">524</option>
            <option value="526">526</option>
            <option value="528">528</option>
            <option value="530">530</option>
            <option value="542">542</option>
            <option value="Mac">Mac</option>
          </select>
        </div>

        <div class="col-md-3"><label class="form-label">PC Number:</label></div>
        <div class="col-md-9">
          <div class="input-group">
            <input type="text" id="selected_pc_display" class="form-control" placeholder="Select a PC from the grid" readonly required>
            <input type="hidden" name="pc_number" id="selected_pc_input">
            <button class="btn btn-outline-secondary" type="button" id="open_pc_modal_btn" disabled>
              Choose PC
            </button>
          </div>
        </div>

        <div class="col-md-3"><label class="form-label">Time In:</label></div>
        <div class="col-md-9"><input type="time" name="reservation_time" class="form-control" required></div>

        <div class="col-md-3"><label class="form-label">Date:</label></div>
        <div class="col-md-9"><input type="date" name="reservation_date" class="form-control" required></div>

        <div class="col-md-3"><label class="form-label">Remaining Session:</label></div>
        <div class="col-md-9"><input class="form-control reservation-readonly" value="<%= remainingSessions %>" readonly></div>
        <div class="col-md-3"></div>
        <div class="col-md-9"><button class="btn btn-primary" type="submit" id="submit_reservation_btn" disabled>Reserve</button></div>
      </form>
    </div>

    <div class="history-card mt-4">
      <h3 class="fw-bold mb-3">Reservation List</h3>
      <div class="table-responsive">
        <table class="table history-table align-middle mb-0">
          <thead>
            <tr>
              <th>Purpose</th>
              <th>Laboratory</th>
              <th>PC</th>
              <th>Schedule</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% if (reservations.length === 0) { %>
            <tr>
              <td colspan="5" class="text-center py-4">No reservations yet.</td>
            </tr>
            <% } %>
            <% reservations.forEach(item => { %>
            <tr>
              <td><%= item.purpose %></td>
              <td><%= item.lab_room %></td>
              <td><%= item.pc_number ? 'PC-' + item.pc_number : 'N/A' %></td>
              <td><%= item.reservation_time %></td>
              <td><span class="badge text-bg-warning"><%= item.status %></span></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>

<!-- PC Selection Modal -->
<div class="modal fade" id="pcSelectionModal" tabindex="-1" aria-labelledby="pcSelectionModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="pcSelectionModalLabel">Select PC - Lab <span id="modal_lab_label"></span></h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="pc-legend mb-3">
          <span class="badge bg-success me-3">Available</span>
          <span class="badge bg-warning text-dark me-3">Reserved</span>
          <span class="badge bg-danger me-3">Not Available</span>
        </div>
        <div id="pc_grid_container" class="pc-grid-container">
          <!-- PC grid will be dynamically generated -->
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
      </div>
    </div>
  </div>
</div>

<style>
  .pc-grid-container {
    display: flex;
    flex-direction: column;
    gap: 8px;
    max-height: 60vh;
    overflow-y: auto;
    padding: 10px;
    background: #f8f9fa;
    border-radius: 8px;
  }

  .pc-grid-row {
    display: flex;
    gap: 8px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .pc-item {
    width: 80px;
    height: 50px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 6px;
    font-weight: 600;
    font-size: 14px;
    cursor: pointer;
    transition: all 0.2s ease;
    border: 2px solid transparent;
    text-align: center;
  }

  .pc-item:hover {
    transform: scale(1.05);
    box-shadow: 0 2px 8px rgba(0,0,0,0.15);
  }

  .pc-item.available {
    background-color: #d4edda;
    color: #155724;
    border-color: #c3e6cb;
  }

  .pc-item.available:hover {
    background-color: #c3e6cb;
    border-color: #28a745;
  }

  .pc-item.available.selected {
    background-color: #28a745;
    color: white;
    border-color: #1e7e34;
    box-shadow: 0 0 0 3px rgba(40, 167, 69, 0.3);
  }

  .pc-item.reserved {
    background-color: #fff3cd;
    color: #856404;
    border-color: #ffeeba;
    cursor: not-allowed;
  }

  .pc-item.not-available {
    background-color: #f8d7da;
    color: #721c24;
    border-color: #f5c6cb;
    cursor: not-allowed;
  }

  .pc-item.reserved:hover,
  .pc-item.not-available:hover {
    transform: none;
    box-shadow: none;
  }

  .pc-row-label {
    text-align: center;
    font-weight: 600;
    color: #6c757d;
    margin-bottom: 4px;
    font-size: 12px;
  }

  .pc-grid-row-wrapper {
    margin-bottom: 12px;
  }
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const labSelect = document.getElementById('lab_room_select');
  const pcModalBtn = document.getElementById('open_pc_modal_btn');
  const pcDisplay = document.getElementById('selected_pc_display');
  const pcInput = document.getElementById('selected_pc_input');
  const submitBtn = document.getElementById('submit_reservation_btn');
  const pcModal = document.getElementById('pcSelectionModal');
  const modalLabLabel = document.getElementById('modal_lab_label');
  const pcGridContainer = document.getElementById('pc_grid_container');

  let currentLab = '';
  let selectedPC = null;
  let pcData = [];

  // Enable PC selection button when lab is selected
  labSelect.addEventListener('change', function() {
    currentLab = this.value;
    if (currentLab) {
      pcModalBtn.disabled = false;
      // Clear previous PC selection when lab changes
      selectedPC = null;
      pcDisplay.value = '';
      pcInput.value = '';
      submitBtn.disabled = true;
    } else {
      pcModalBtn.disabled = true;
    }
  });

  // Open PC selection modal
  pcModalBtn.addEventListener('click', function() {
    if (!currentLab) return;
    modalLabLabel.textContent = currentLab;
    loadPCsForLab(currentLab);
    const modal = new bootstrap.Modal(pcModal);
    modal.show();
  });

      // Load PCs for selected lab
  function loadPCsForLab(lab) {
    pcGridContainer.innerHTML = '<div class="text-center py-4"><div class="spinner-border text-primary" role="status"><span class="visually-hidden">Loading...</span></div></div>';

    fetch(`/dashboard/api/lab-pcs?lab=${encodeURIComponent(lab)}`)
      .then(response => response.json())
      .then(data => {
        pcData = data;
        renderPCGrid(data);
      })
      .catch(error => {
        console.error('Error loading PCs:', error);
        pcGridContainer.innerHTML = '<div class="text-center text-danger py-4">Failed to load PC data.</div>';
      });
  }

  // Render PC grid (10 PCs per row)
  function renderPCGrid(pcs) {
    pcGridContainer.innerHTML = '';

    // Sort PCs by number
    pcs.sort((a, b) => a.pc_number - b.pc_number);

    // Create rows of 10 PCs each
    for (let row = 0; row < 5; row++) {
      const rowWrapper = document.createElement('div');
      rowWrapper.className = 'pc-grid-row-wrapper';

      const rowLabel = document.createElement('div');
      rowLabel.className = 'pc-row-label';
      const startPC = row * 10 + 1;
      const endPC = (row + 1) * 10;
      rowLabel.textContent = `PC ${startPC} - ${endPC}`;
      rowWrapper.appendChild(rowLabel);

      const rowDiv = document.createElement('div');
      rowDiv.className = 'pc-grid-row';

      for (let col = 0; col < 10; col++) {
        const pcIndex = row * 10 + col;
        const pc = pcs[pcIndex];

        if (pc) {
          const pcItem = document.createElement('div');
          pcItem.className = `pc-item ${pc.status}`;
          pcItem.textContent = `PC-${pc.pc_number}`;
          pcItem.dataset.pcNumber = pc.pc_number;
          pcItem.dataset.status = pc.status;

          if (pc.status === 'available') {
            pcItem.addEventListener('click', function() {
              // Remove selection from previously selected PC
              const prevSelected = pcGridContainer.querySelector('.pc-item.selected');
              if (prevSelected) {
                prevSelected.classList.remove('selected');
              }

              // Select this PC
              pcItem.classList.add('selected');
              selectedPC = pc.pc_number;
            });
          }

          rowDiv.appendChild(pcItem);
        }
      }

      rowWrapper.appendChild(rowDiv);
      pcGridContainer.appendChild(rowWrapper);
    }
  }

  // Handle modal close with selection
  pcModal.addEventListener('hidden.bs.modal', function() {
    if (selectedPC) {
      pcDisplay.value = `PC-${selectedPC}`;
      pcInput.value = selectedPC;
      submitBtn.disabled = false;
    }
  });

  // Form validation - prevent submission without PC selection
  document.querySelector('form').addEventListener('submit', function(e) {
    if (!pcInput.value) {
      e.preventDefault();
      alert('Please select a PC for your reservation.');
      return false;
    }
  });
});
</script>