<section class="py-3 py-lg-4">
  <div class="container-fluid px-lg-3">
    <div class="row g-3">
      <div class="col-xl-3">
        <div class="panel-card h-100">
          <div class="panel-header">Student Information</div>
          <div class="panel-body text-center">
            <div class="student-avatar mx-auto mb-4">
              <img src="/profile-image/<%= user.image_url %>" alt="Student Profile" class="img-fluid rounded-circle border shadow-sm" style="width: 160px; height: 160px; object-fit: cover;" />
            </div>

            <div class="student-details text-start">
              <p>
                <i class="bi bi-person-fill"></i>
                <strong>Name:</strong>
                <%= user.first_name %>
                <%= user.middle_name || '' %>
                <%= user.last_name %>
              </p>
              <p>
                <i class="bi bi-mortarboard-fill"></i>
                <strong>Course:</strong>
                <%= user.course %>
              </p>
              <p>
                <i class="bi bi-arrow-through-heart-fill"></i>
                <strong>Year:</strong>
                <%= user.course_level %>
              </p>
              <p>
                <i class="bi bi-envelope-fill"></i>
                <strong>Email:</strong>
                <%= user.email %>
              </p>
              <p>
                <i class="bi bi-postcard-fill"></i>
                <strong>Address:</strong>
                <%= user.address %>
              </p>
              <p>
                <i class="bi bi-stopwatch-fill"></i>
                <strong>Session:</strong>
                <%= remainingSessions %>
              </p>
            </div>
          </div>
        </div>
      </div>

      <div class="col-xl-4">
        <div class="panel-card h-100">
          <div class="panel-header d-flex align-items-center gap-2">
            <i class="bi bi-megaphone-fill"></i> Announcement
          </div>
          <div class="panel-body panel-scroll">
            <% announcements.forEach((item, index) => { %>
            <div class="announcement-item <%= index !== announcements.length - 1 ? 'with-border' : '' %>">
              <h5><%= item.author %> | <%= item.date %></h5>
              <div class="announcement-box"><%= item.body %></div>
            </div>
            <% }) %>
          </div>
        </div>
      </div>

      <div class="col-xl-5">
        <div class="panel-card h-100">
          <div class="panel-header">Rules and Regulation</div>
          <div class="panel-body panel-scroll rules-panel">
            <h2 class="text-center fw-bold mb-2">University of Cebu</h2>
            <h4 class="text-center fw-bold mb-4">
              COLLEGE OF INFORMATION &amp; COMPUTER STUDIES
            </h4>
            <h5 class="fw-bold mb-4">LABORATORY RULES AND REGULATIONS</h5>
            <p>
              To avoid embarrassment and maintain camaraderie with your friends
              and superiors at our laboratories, please observe the following:
            </p>
            <ol class="rules-list">
              <% rules.forEach(rule => { %>
              <li><%= rule %></li>
              <% }) %>
            </ol>
          </div>
        </div>
      </div>
    </div>

    <div class="row g-3 mt-1">
      <div class="col-md-4">
        <div class="summary-card">
          <span>Completed Sessions</span>
          <strong><%= completedSessions %></strong>
        </div>
      </div>

      <div class="col-md-4">
        <div class="summary-card">
          <span>Active Sessions</span>
          <strong><%= activeSessions %></strong>
        </div>
      </div>

      <div class="col-md-4">
        <div class="summary-card">
          <span>Pending Reservations</span>
          <strong><%= pendingReservations %></strong>
        </div>
      </div>
    </div>

    <div class="row g-3 mt-3">
      <div class="col-xl-6">
        <div class="panel-card h-100">
          <div class="panel-header d-flex align-items-center justify-content-between">
            <span>Time In</span>
            <span class="text small">Remaining: <%= remainingSessions %></span>
          </div>
          <div class="panel-body">
            <% if (activeSessions > 0) { %>
              <div class="alert alert-info py-2 mb-3" role="alert">
                You already have an active sit-in session. Time In is disabled until you time-out.
              </div>
            <% } %>

            <form action="/dashboard/time-in?returnTo=/dashboard" method="POST" class="row g-3 align-items-end">
              <div class="col-12">
                <label class="form-label fw-semibold">Lab Room</label>
                <select
                  name="lab_room"
                  class="form-select"
                  required
                  <%= activeSessions > 0 ? 'disabled' : '' %>
                >
                  <option value="" disabled selected>Select laboratory</option>
                  <option value="524">524</option>
                  <option value="526">526</option>
                  <option value="528">528</option>
                  <option value="Networking Lab">Networking Lab</option>
                </select>
              </div>

              <div class="col-12">
                <label class="form-label fw-semibold">Purpose</label>
                <textarea
                  name="purpose"
                  class="form-control"
                  rows="4"
                  placeholder="Ex. Programming activity, research, project work"
                  required
                  <%= activeSessions > 0 ? 'disabled' : '' %>
                ></textarea>
              </div>

              <div class="col-12">
                <button
                  class="btn btn-primary w-100 py-2"
                  type="submit"
                  <%= activeSessions > 0 ? 'disabled' : '' %>
                >
                  Time In
                </button>
              </div>
            </form>
          </div>
        </div>
      </div>

      <div class="col-xl-6">
        <div class="panel-card h-100">
          <div class="panel-header">Recent Sit-in Records</div>
          <div class="panel-body table-responsive">
            <table class="table table-bordered align-middle mb-0">
              <thead>
                <tr>
                  <th>Lab</th>
                  <th>Purpose</th>
                  <th>Status</th>
                  <th>Time In</th>
                  <th>Time Out</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody>
                <% if (!recentRecords.length) { %>
                  <tr>
                    <td colspan="6" class="text-center py-4 text-muted">No sit-in records found.</td>
                  </tr>
                <% } %>

                <% recentRecords.forEach(record => { %>
                  <tr>
                    <td><%= record.lab_room %></td>
                    <td><%= record.purpose %></td>
                    <td>
                      <span
                        class="badge <%= record.status === 'Active' ? 'bg-success' : 'bg-secondary' %>"
                      >
                        <%= record.status %>
                      </span>
                    </td>
                    <td>
                      <%= record.time_in ? new Date(record.time_in).toLocaleString() : '-' %>
                    </td>
                    <td>
                      <%= record.time_out ? new Date(record.time_out).toLocaleString() : '-' %>
                    </td>
                    <td>
                      <% if (record.status === 'Active') { %>
                        <form action="/dashboard/time-out/<%= record.id %>?returnTo=/dashboard" method="POST">
                          <button class="btn btn-success btn-sm" type="submit">Time Out</button>
                        </form>
                      <% } else { %>
                        <span class="text-muted small">No action</span>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

    <div class="row g-3 mt-1">
      <div class="col-12">
        <div class="panel-card">
          <div class="panel-header d-flex align-items-center justify-content-between">
            <span>Your Reservations</span>
            <span class="text small">Pending: <%= pendingReservations %></span>
          </div>
          <div class="panel-body table-responsive">
            <table class="table table-bordered align-middle mb-0">
              <thead>
                <tr>
                  <th>Purpose</th>
                  <th>Laboratory</th>
                  <th>Schedule</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody>
                <% if (!recentReservations.length) { %>
                  <tr>
                    <td colspan="4" class="text-center py-4 text-muted">No reservations yet.</td>
                  </tr>
                <% } %>

                <% recentReservations.forEach(item => { %>
                  <%
                    const badgeClass =
                      item.status === 'Pending'
                        ? 'text-bg-warning'
                        : item.status === 'Approved'
                          ? 'text-bg-success'
                          : item.status === 'Rejected'
                            ? 'text-bg-danger'
                            : 'text-bg-secondary';
                  %>
                  <tr>
                    <td><%= item.purpose %></td>
                    <td><%= item.lab_room %></td>
                    <td><%= item.reservation_time ? new Date(item.reservation_time).toLocaleString() : '-' %></td>
                    <td>
                      <span class="badge <%= badgeClass %>"><%= item.status %></span>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>