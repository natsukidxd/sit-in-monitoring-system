<section class="py-3 py-lg-4">
  <div class="container-fluid px-lg-3">
    <div class="row g-3">
      <div class="col-xl-3">
        <div class="panel-card h-100">
          <div class="panel-header">Student Information</div>
          <div class="panel-body text-center">
            <div class="student-avatar mx-auto mb-4">
              <img src="/profile-image/<%= user.image_url %>" alt="Student Profile" class="img-fluid rounded-circle border shadow-sm" style="width: 160px; height: 160px; object-fit: cover;" />
            </div>

            <div class="student-details text-start">
              <p>
                <i class="bi bi-person-fill"></i>
                <strong>Name:</strong>
                <%= user.first_name %>
                <%= user.middle_name || '' %>
                <%= user.last_name %>
              </p>
              <p>
                <i class="bi bi-mortarboard-fill"></i>
                <strong>Course:</strong>
                <%= user.course %>
              </p>
              <p>
                <i class="bi bi-arrow-through-heart-fill"></i>
                <strong>Year:</strong>
                <%= user.course_level %>
              </p>
              <p>
                <i class="bi bi-envelope-fill"></i>
                <strong>Email:</strong>
                <%= user.email %>
              </p>
              <p>
                <i class="bi bi-postcard-fill"></i>
                <strong>Address:</strong>
                <%= user.address %>
              </p>
              <p>
                <i class="bi bi-stopwatch-fill"></i>
                <strong>Session:</strong>
                <%= remainingSessions %>
              </p>
            </div>
          </div>
        </div>
      </div>

      <div class="col-xl-4">
        <div class="panel-card h-100">
          <div class="panel-header d-flex align-items-center gap-2">
            <i class="bi bi-megaphone-fill"></i> Announcement
          </div>
          <div class="panel-body panel-scroll">
            <% announcements.forEach((item, index) => { %>
            <div class="announcement-item <%= index !== announcements.length - 1 ? 'with-border' : '' %>">
              <h5><%= item.author %> | <%= item.date %></h5>
              <div class="announcement-box"><%= item.body %></div>
            </div>
            <% }) %>
          </div>
        </div>
      </div>

      <div class="col-xl-5">
        <div class="panel-card h-100">
          <div class="panel-header">Rules and Regulation</div>
          <div class="panel-body rules-panel">
            <h2 class="text-center fw-bold mb-2">University of Cebu</h2>
            <h4 class="text-center fw-bold mb-4">
              COLLEGE OF INFORMATION &amp; COMPUTER STUDIES
            </h4>
            <h5 class="text-center mb-4">LABORATORY RULES AND REGULATIONS</h5>
            <p>
              To avoid embarrassment and maintain camaraderie with your friends
              and superiors at our laboratories, please observe the following:
            </p>
            <ol class="rules-list">
              <% rules.forEach(rule => { %>
              <li><%= rule %></li>
              <% }) %>
            </ol>
          </div>
        </div>
      </div>
     </div>
   </div>

   <!-- Sit-in Summary Section -->
   <div class="row g-3 mt-2">
     <div class="col-12">
       <div class="panel-card">
         <div class="panel-header">
           <i class="bi bi-graph-up-arrow"></i> Your Sit-in Summary
         </div>
         <div class="panel-body">
           <div class="row g-4 text-center">
             <div class="col-md-3 col-6">
               <div class="p-3 bg-primary bg-opacity-10 rounded-3">
                 <h3 class="text-primary mb-1"><%= sitinSummary?.totalHours || '0.0' %></h3>
                 <p class="text-muted mb-0"><i class="bi bi-clock-fill"></i> Total Hours</p>
               </div>
             </div>
             <div class="col-md-3 col-6">
               <div class="p-3 bg-success bg-opacity-10 rounded-3">
                 <h3 class="text-success mb-1"><%= sitinSummary?.totalSessions || '0' %></h3>
                 <p class="text-muted mb-0"><i class="bi bi-check-circle-fill"></i> Completed Sessions</p>
               </div>
             </div>
             <div class="col-md-3 col-6">
               <div class="p-3 bg-info bg-opacity-10 rounded-3">
                 <h3 class="text-info mb-1"><%= sitinSummary?.averageDuration || '0 mins' %></h3>
                 <p class="text-muted mb-0"><i class="bi bi-hourglass-split"></i> Average Session</p>
               </div>
             </div>
             <div class="col-md-3 col-6">
               <div class="p-3 bg-warning bg-opacity-10 rounded-3">
                 <h3 class="text-warning mb-1"><%= sitinSummary?.longestSession || '0 mins' %></h3>
                 <p class="text-muted mb-0"><i class="bi bi-trophy-fill"></i> Longest Session</p>
               </div>
             </div>
           </div>
         </div>
       </div>
     </div>
   </div>
 </section>
