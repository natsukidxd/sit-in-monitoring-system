<section class="py-4">
  <div class="container">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
      <div>
        <h1 class="h3 mb-1">Dashboard</h1>
        <p class="text-secondary mb-0">Welcome, <strong><%= currentUser.name %></strong> (<%= currentUser.id_number %>)</p>
      </div>
    </div>

    <div class="row g-4 mb-4">
      <div class="col-md-4">
        <div class="stat-card">
          <div class="stat-label">Total sessions</div>
          <div class="stat-value"><%= totalSessions %></div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="stat-card">
          <div class="stat-label">Active sessions</div>
          <div class="stat-value"><%= activeSessions %></div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="stat-card">
          <div class="stat-label">Course</div>
          <div class="stat-value small-value"><%= currentUser.course %></div>
        </div>
      </div>
    </div>

    <div class="row g-4">
      <div class="col-lg-4">
        <div class="card shadow-sm border-0">
          <div class="card-body p-4">
            <h2 class="h5 mb-3">New sit-in record</h2>
            <form action="/dashboard/time-in" method="POST" class="vstack gap-3">
              <div>
                <label class="form-label">Lab Room</label>
                <select class="form-select" name="lab_room" required>
                  <option value="" disabled selected>Select lab room</option>
                  <option>Lab 524</option>
                  <option>Lab 526</option>
                  <option>Lab 528</option>
                  <option>Networking Lab</option>
                </select>
              </div>
              <div>
                <label class="form-label">Purpose</label>
                <textarea class="form-control" name="purpose" rows="4" placeholder="Ex. Programming activity, research, project work" required></textarea>
              </div>
              <button class="btn btn-primary" type="submit">Time In</button>
            </form>
          </div>
        </div>
      </div>

      <div class="col-lg-8">
        <div class="card shadow-sm border-0">
          <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
              <h2 class="h5 mb-0">Sit-in history</h2>
            </div>
            <div class="table-responsive">
              <table class="table align-middle">
                <thead>
                  <tr>
                    <th>Lab</th>
                    <th>Purpose</th>
                    <th>Time In</th>
                    <th>Status</th>
                    <th>Action</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (records.length === 0) { %>
                    <tr>
                      <td colspan="5" class="text-center text-secondary py-4">No sit-in records yet.</td>
                    </tr>
                  <% } %>
                  <% records.forEach(record => { %>
                    <tr>
                      <td><%= record.lab_room %></td>
                      <td><%= record.purpose %></td>
                      <td><%= record.time_in %></td>
                      <td>
                        <span class="badge <%= record.status === 'Active' ? 'text-bg-success' : 'text-bg-secondary' %>"><%= record.status %></span>
                      </td>
                      <td>
                        <% if (record.status === 'Active') { %>
                          <form action="/dashboard/time-out/<%= record.id %>" method="POST">
                            <button class="btn btn-sm btn-outline-danger">Time Out</button>
                          </form>
                        <% } else { %>
                          <span class="text-secondary small"><%= record.time_out || 'Completed' %></span>
                        <% } %>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
