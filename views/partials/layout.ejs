<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    <%= title %> | Sit-in Monitoring System
  </title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>

<body>
  <%- include('navbar') %>

    <main>
      <% if (message && !loginSuccess) { %>
        <div class="container mt-3">
          <div class="alert alert-success alert-dismissible fade show" role="alert">
            <%= message %>
              <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        </div>
        <% } %>

          <% if (error) { %>
            <div class="container mt-3">
              <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <%= error %>
                  <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
              </div>
            </div>
            <% } %>

              <%- body %>
    </main>

    <% if (loginSuccess && message) { %>
      <div class="modal fade" id="loginSuccessModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static"
        data-bs-keyboard="false">
        <div class="modal-dialog modal-dialog-centered" style="max-width: 720px; width: 90vw;">
          <div class="modal-content" style="border-radius: 18px; overflow: hidden;">
            <div class="modal-header border-0"
              style="background: linear-gradient(90deg, #124d99, #1e57a2); padding: 1.5rem 1.5rem 1rem;">
              <div class="d-flex align-items-center gap-3">
                <i class="bi bi-check-circle-fill" style="font-size: 2.2rem; color: #ffffff;"></i>
                <div>
                  <h5 class="modal-title text-white fw-bold mb-1">Login Successful</h5>
                  <div class="text-white-50 small">Welcome back. Please continue.</div>
                </div>
              </div>
              <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                aria-label="Close"></button>
            </div>

            <div class="modal-body d-flex align-items-center justify-content-center p-4">
              <div class="text-center">

                <img src="<% if (currentUser && currentUser.role === 'admin') { %>
                  /profile-image/<%= admin?.image_url || 'default.png' %>
                <% } else { %>
                  /profile-image/<%= user.image_url %>
                <% } %>" alt="Profile Picture" class="rounded-circle border shadow-sm"
                  style="width: 96px; height: 96px; object-fit: cover;" />

                <p class="lead fw-semibold mb-3 mt-3">
                  <%= message %>
                </p>
                <div class="d-flex align-items-center justify-content-center gap-3">
                  <a href="<%= currentUser && currentUser.role === 'admin' ? '/admin' : '/dashboard' %>"
                    class="btn btn-success btn-lg px-5" data-bs-dismiss="modal">
                    Continue
                  </a>
                  <button type="button" class="btn btn-outline-secondary btn-lg px-4" data-bs-dismiss="modal">
                    Close
                  </button>
                </div>
                <div class="text-muted small mt-3">
                  You can continue using the dashboard right away.
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
      <% } %>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

        <% if (loginSuccess && message) { %>
          <script>
            (function () {
              var modalEl = document.getElementById("loginSuccessModal");
              if (!modalEl) return;
              var modal = new bootstrap.Modal(modalEl, {
                backdrop: "static",
                keyboard: false,
              });
              modal.show();
            })();
          </script>
          <% } %>
</body>

</html>