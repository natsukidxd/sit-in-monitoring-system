  <script>
    (function () {
      var navLink = document.getElementById("adminStudentSearchNavLink");
      var form = document.getElementById("adminStudentSearchForm");
      var input = document.getElementById("adminStudentSearchInput");
      var resultsEl = document.getElementById("adminStudentSearchResults");
      var sitInModalEl = document.getElementById("adminStudentSitInModal");
      var searchModalEl = document.getElementById("adminStudentSearchModal");
      var sitInStudentDisplay = document.getElementById("adminStudentSitInModalStudentDisplay");
      var sitInActiveAlert = document.getElementById("adminStudentSitInModalActiveAlert");
      var timeInForm = document.getElementById("adminStudentSitInModalTimeInForm");
      var timeOutForm = document.getElementById("adminStudentSitInModalTimeOutForm");
      var timeInStudentId = document.getElementById("adminStudentSitInModalTimeInStudentId");
      var timeOutStudentId = document.getElementById("adminStudentSitInModalTimeOutStudentId");
      var timeInReturnTo = document.getElementById("adminStudentSitInModalTimeInReturnTo");
      var timeOutReturnTo = document.getElementById("adminStudentSitInModalTimeOutReturnTo");
      var timeInLabRoom = document.getElementById("adminStudentSitInModalLabRoom");
      var timeInPcNumber = document.getElementById("adminStudentSitInModalPcNumber");
      var timeInPcHelp = document.getElementById("adminStudentSitInModalPcHelp");

      if (!navLink || !form || !input || !resultsEl) return;

      navLink.addEventListener("click", function (e) {
        // Prevent jumping to the top when href="#" is used.
        e.preventDefault();
      });

      function setResultsHtml(html) {
        resultsEl.innerHTML = html;
      }

      function resetPcOptions(message) {
        if (!timeInPcNumber) return;
        timeInPcNumber.innerHTML = '<option value="" selected disabled>' + escapeHtml(message || "Select lab first") + "</option>";
        timeInPcNumber.disabled = true;
      }

      function setPcOptions(pcs) {
        if (!timeInPcNumber) return;
        var options = ['<option value="" selected disabled>Select a PC</option>'];
        pcs.forEach(function (pc) {
          options.push('<option value="' + escapeHtml(pc) + '">PC-' + escapeHtml(pc) + "</option>");
        });
        timeInPcNumber.innerHTML = options.join("");
        timeInPcNumber.disabled = pcs.length === 0;
      }

      async function loadAvailablePcs(labRoom) {
        if (!timeInLabRoom || !timeInPcNumber) return;
        if (!labRoom) {
          resetPcOptions("Select lab first");
          if (timeInPcHelp) timeInPcHelp.textContent = "Choose a laboratory to load available PCs.";
          return;
        }

        resetPcOptions("Loading available PCs...");
        if (timeInPcHelp) timeInPcHelp.textContent = "Fetching available PCs...";

        try {
          var response = await fetch(
            "/admin/student-sitin/available-pcs?lab_room=" + encodeURIComponent(labRoom),
            { headers: { Accept: "application/json" } }
          );
          if (!response.ok) {
            throw new Error("Request failed");
          }

          var payload = await response.json();
          var pcs = payload && Array.isArray(payload.pcs) ? payload.pcs : [];
          if (!pcs.length) {
            resetPcOptions("No available PCs");
            if (timeInPcHelp) timeInPcHelp.textContent = "No available PCs found for this laboratory.";
            return;
          }

          setPcOptions(pcs);
          if (timeInPcHelp) timeInPcHelp.textContent = pcs.length + " PC(s) available in this laboratory.";
        } catch (error) {
          console.error(error);
          resetPcOptions("Unable to load PCs");
          if (timeInPcHelp) timeInPcHelp.textContent = "Could not load PCs. Please try again.";
        }
      }

      function escapeHtml(value) {
        return String(value ?? "").replace(/[&<>"']/g, function (ch) {
          if (ch === "&") return "&amp;";
          if (ch === "<") return "&lt;";
          if (ch === ">") return "&gt;";
          if (ch === '"') return "&quot;";
          return "&#39;";
        });
      }

      function renderResultsTable(results) {
        var rowsHtml = results
          .map(function (student) {
            var studentId = String(student.id || "").trim();
            var idNumber = String(student.id_number || "").trim();
            var fullName =
              String(student.first_name || "").trim() +
              " " +
              String(student.last_name || "").trim();
            var course = student.course || "-";
            var year = student.course_level || "-";
            var sessionsLeft =
              student.sessions_left === null || student.sessions_left === undefined
                ? 30
                : student.sessions_left;
            var hasActive = Number(student.active_sessions) > 0;
            var badgeClass = hasActive ? "bg-success" : "bg-secondary";
            var badgeLabel = hasActive ? "Active" : "Idle";

            return `
              <tr>
                <td class="text-nowrap">${escapeHtml(idNumber || "-")}</td>
                <td>${escapeHtml(fullName.trim() || "-")}</td>
                <td>${escapeHtml(course)}</td>
                <td class="text-center">${escapeHtml(year)}</td>
                <td class="text-center">${escapeHtml(sessionsLeft)}</td>
                <td class="text-center">
                  <span class="badge ${badgeClass}">${badgeLabel}</span>
                </td>
                <td class="text-center">
                  <button
                    class="btn btn-sm btn-primary"
                    type="button"
                    data-action="sit-in"
                    data-student-id="${escapeHtml(studentId)}"
                    data-id-number="${escapeHtml(idNumber)}"
                    data-first-name="${escapeHtml(String(student.first_name || "").trim())}"
                    data-last-name="${escapeHtml(String(student.last_name || "").trim())}"
                    data-active-sessions="${escapeHtml(Number(student.active_sessions || 0))}"
                    ${idNumber ? "" : "disabled"}
                  >
                    Sit-in
                  </button>
                </td>
              </tr>
            `;
          })
          .join("");

        var note =
          results.length >= 25
            ? '<div class="text-muted small mb-2">Showing up to 25 results. Refine your search to narrow it down.</div>'
            : '<div class="text-muted small mb-2">Select a student to sit-in.</div>';

        return `
          ${note}
          <div class="table-responsive">
            <table class="table table-bordered align-middle mb-0">
              <thead>
                <tr>
                  <th style="width: 120px;">ID Number</th>
                  <th style="width: 240px;">Student</th>
                  <th style="width: 100px;">Course</th>
                  <th style="width: 60px;" class="text-center">Year</th>
                  <th style="width: 90px;" class="text-center">Sessions</th>
                  <th style="width: 90px;" class="text-center">Status</th>
                  <th style="width: 90px;" class="text-center">Action</th>
                </tr>
              </thead>
              <tbody>
                ${rowsHtml}
              </tbody>
            </table>
          </div>
        `;
      }

      resultsEl.addEventListener("click", function (e) {
        var btn = e.target && e.target.closest
          ? e.target.closest('button[data-action="sit-in"]')
          : null;
        if (!btn) return;

        var studentId = String(btn.getAttribute("data-student-id") || "").trim();
        var idNumber = String(btn.getAttribute("data-id-number") || "").trim();
        var firstName = String(btn.getAttribute("data-first-name") || "").trim();
        var lastName = String(btn.getAttribute("data-last-name") || "").trim();
        var activeSessions = Number(btn.getAttribute("data-active-sessions") || 0);

        if (!studentId) {
          if (!idNumber) return;
          window.location.href =
            "/admin/student-sitin?q=" + encodeURIComponent(idNumber);
          return;
        }

        if (!window.bootstrap || !window.bootstrap.Modal || !sitInModalEl) {
          window.location.href =
            "/admin/student-sitin?q=" + encodeURIComponent(idNumber);
          return;
        }

        if (sitInStudentDisplay) {
          sitInStudentDisplay.value =
            (idNumber ? idNumber + " - " : "") + (firstName + " " + lastName).trim();
        }

        var returnTo = window.location.pathname + window.location.search;
        if (timeInForm && typeof timeInForm.reset === "function") {
          timeInForm.reset();
        }
        resetPcOptions("Select lab first");
        if (timeInPcHelp) timeInPcHelp.textContent = "Choose a laboratory to load available PCs.";
        if (timeInStudentId) timeInStudentId.value = studentId;
        if (timeOutStudentId) timeOutStudentId.value = studentId;
        if (timeInReturnTo) timeInReturnTo.value = returnTo;
        if (timeOutReturnTo) timeOutReturnTo.value = returnTo;

        if (activeSessions > 0) {
          if (sitInActiveAlert) sitInActiveAlert.style.display = "block";
          if (timeOutForm) timeOutForm.style.display = "block";
          if (timeInForm) timeInForm.style.display = "none";
        } else {
          if (sitInActiveAlert) sitInActiveAlert.style.display = "none";
          if (timeOutForm) timeOutForm.style.display = "none";
          if (timeInForm) timeInForm.style.display = "block";
        }

        try {
          if (searchModalEl) {
            var searchModal = window.bootstrap.Modal.getInstance(searchModalEl);
            if (searchModal) searchModal.hide();
          }
        } catch (err) {}

        var sitInModal = window.bootstrap.Modal.getOrCreateInstance(sitInModalEl);
        sitInModal.show();
      });

      if (timeInLabRoom) {
        timeInLabRoom.addEventListener("change", function () {
          loadAvailablePcs(String(timeInLabRoom.value || "").trim());
        });
      }

      form.addEventListener("submit", async function (e) {
        e.preventDefault();

        var q = String(input.value || "").trim();
        if (!q) {
          setResultsHtml('<div class="alert alert-info mb-0">Enter a student ID number or name.</div>');
          return;
        }

        setResultsHtml(
          '<div class="d-flex align-items-center gap-2 text-muted"><div class="spinner-border spinner-border-sm" role="status"></div> Searching...</div>'
        );

        try {
          var resp = await fetch(
            "/admin/student-sitin/search?q=" + encodeURIComponent(q),
            { headers: { Accept: "application/json" } }
          );

          if (!resp.ok) {
            setResultsHtml('<div class="alert alert-danger mb-0">Unable to search students.</div>');
            return;
          }

          var payload = await resp.json();
          var results = (payload && payload.results) || [];

          if (!results.length) {
            setResultsHtml('<div class="alert alert-secondary mb-0">No matching student found.</div>');
            return;
          }

          setResultsHtml(renderResultsTable(results));
        } catch (err) {
          console.error(err);
          setResultsHtml('<div class="alert alert-danger mb-0">Unexpected error while searching.</div>');
        }
      });
    })();
  </script>
<% } %>

<script>
  (function () {
    const notificationDropdown = document.getElementById('notificationDropdown');
    const notificationBadge = document.getElementById('notificationBadge');
    const notificationList = document.getElementById('notificationList');
    const markAllReadBtn = document.getElementById('markAllReadBtn');

    let notificationTimer = null;

    function formatTimeAgo(dateString) {
      const now = new Date();
      const date = new Date(dateString);
      const diffMs = now - date;
      const diffMins = Math.floor(diffMs / 60000);
      const diffHours = Math.floor(diffMins / 60);
      const diffDays = Math.floor(diffHours / 24);

      if (diffMins < 1) return 'Just now';
      if (diffMins < 60) return `${diffMins}m ago`;
      if (diffHours < 24) return `${diffHours}h ago`;
      if (diffDays < 7) return `${diffDays}d ago`;
      return date.toLocaleDateString();
    }

    async function fetchNotifications() {
      try {
        const response = await fetch('/api/notifications');
        if (!response.ok) throw new Error('Failed to fetch notifications');
        
        const data = await response.json();
        if (data.success) {
          renderNotifications(data.notifications);
        } else {
          renderNotifications([]);
        }
      } catch (error) {
        console.error('Error fetching notifications:', error);
        renderNotifications([]);
      }
    }

    async function fetchUnreadCount() {
      try {
        const response = await fetch('/api/notifications/unread-count');
        if (!response.ok) throw new Error('Failed to fetch unread count');
        
        const data = await response.json();
        if (data.success) {
          updateBadge(data.count);
        }
      } catch (error) {
        console.error('Error fetching unread count:', error);
      }
    }

    function updateBadge(count) {
      if (count > 0) {
        notificationBadge.textContent = count;
        notificationBadge.style.display = 'inline-block';
        markAllReadBtn.style.display = 'inline';
      } else {
        notificationBadge.style.display = 'none';
        markAllReadBtn.style.display = 'none';
      }
    }

    function renderNotifications(notifications) {
      if (!notifications || notifications.length === 0) {
        notificationList.innerHTML = `
          <div class="text-center py-3">
            <i class="bi bi-bell-slash text-muted" style="font-size: 2rem;"></i>
            <p class="text-muted mt-2 mb-0">No notifications</p>
          </div>
        `;
        return;
      }

      const hasUnread = notifications.some(n => !n.isRead);
      
      notificationList.innerHTML = notifications.map(notification => {
        const isUnread = !notification.isRead;
        const timeAgo = formatTimeAgo(notification.createdAt);
        
        return `
          <div class="dropdown-item notification-item ${isUnread ? 'bg-light' : ''}" data-id="${notification.id}">
            <div class="d-flex align-items-start gap-2">
              <div class="flex-shrink-0">
                <div class="bg-primary rounded-circle d-flex align-items-center justify-content-center" style="width: 36px; height: 36px;">
                  <i class="bi bi-${getTypeIcon(notification.type)} text-white"></i>
                </div>
              </div>
              <div class="flex-grow-1">
                <div class="d-flex justify-content-between align-items-start">
                  <h6 class="mb-1 fw-semibold">${escapeHtml(notification.title)}</h6>
                  <small class="text-muted">${timeAgo}</small>
                </div>
                <p class="mb-2 text-muted small">${escapeHtml(notification.message)}</p>
                <div class="d-flex justify-content-between align-items-center">
                  <span class="badge bg-secondary">${escapeHtml(notification.type.replace('_', ' '))}</span>
                  ${isUnread ? `
                    <button class="btn btn-sm btn-outline-primary mark-read-btn" data-id="${notification.id}">
                      Mark as read
                    </button>
                  ` : ''}
                </div>
              </div>
            </div>
            ${!isUnread ? '<hr class="my-2">' : ''}
          </div>
        `;
      }).join('');
    }

    function getTypeIcon(type) {
      switch (type) {
        case 'reservation_approved': return 'check-circle-fill';
        case 'reservation_rejected': return 'x-circle-fill';
        case 'announcement': return 'megaphone-fill';
        default: return 'bell-fill';
      }
    }

    function escapeHtml(value) {
      return String(value ?? "").replace(/[&<>"']/g, function (ch) {
        if (ch === '&') return '&' + 'amp;';
        if (ch === '<') return '&' + 'lt;';
        if (ch === '>') return '&' + 'gt;';
        if (ch === '"') return '&' + 'quot;';
        if (ch === "'") return '&' + '#39;';
        return ch;
      });
    }

    async function markAsRead(notificationId) {
      try {
        const response = await fetch(`/api/notifications/${notificationId}/mark-read`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' }
        });
        
        if (response.ok) {
          fetchNotifications();
          fetchUnreadCount();
        }
      } catch (error) {
        console.error('Error marking notification as read:', error);
      }
    }

    async function markAllAsRead() {
      try {
        const response = await fetch('/api/notifications/mark-all-read', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' }
        });
        
        if (response.ok) {
          fetchNotifications();
          fetchUnreadCount();
        }
      } catch (error) {
        console.error('Error marking all notifications as read:', error);
      }
    }

    // Initial fetch and set up polling
    if (notificationDropdown && notificationList) {
      // Event listeners
      notificationList.addEventListener('click', function(e) {
        const markReadBtn = e.target.closest('.mark-read-btn');
        if (markReadBtn) {
          const notificationId = markReadBtn.getAttribute('data-id');
          markAsRead(notificationId);
        }
      });

      if (markAllReadBtn) {
        markAllReadBtn.addEventListener('click', markAllAsRead);
      }

      // Fetch notifications when dropdown is opened
      notificationDropdown.addEventListener('show.bs.dropdown', () => {
        fetchNotifications();
      });

      fetchUnreadCount();
      fetchNotifications();
      
      // Poll for new notifications every 30 seconds
      notificationTimer = setInterval(() => {
        fetchUnreadCount();
      }, 30000);
    } else {
      // If notification elements don't exist, clear the loading message
      if (notificationList) {
        notificationList.innerHTML = `
          <div class="text-center py-3">
            <i class="bi bi-bell-slash text-muted" style="font-size: 2rem;"></i>
            <p class="text-muted mt-2 mb-0">No notifications</p>
          </div>
        `;
      }
    }

    // Clean up timer on page unload
    window.addEventListener('beforeunload', () => {
      if (notificationTimer) {
        clearInterval(notificationTimer);
      }
    });
  })();
</script>
