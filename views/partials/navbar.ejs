        <div class="modal-footer">
          <button type="submit" form="adminStudentAddForm" class="btn btn-primary">Add Student</button>
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
        </div>
      </div>
    </div>
  </div>
  <div
    class="modal fade"
    id="adminStudentSearchModal"
    tabindex="-1"
    aria-labelledby="adminStudentSearchModalLabel"
    aria-hidden="true"
  >
    <div class="modal-dialog modal-dialog-centered" style="max-width: 1080px; width: 95vw;">
      <div class="modal-content" style="border-radius: 14px;">
        <div class="modal-header">
          <h5 class="modal-title" id="adminStudentSearchModalLabel">Search Student</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>

        <div class="modal-body">
          <form id="adminStudentSearchForm" class="row g-2" autocomplete="off">
