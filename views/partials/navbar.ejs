  <div
    class="modal fade"
    id="adminStudentSitInModal"
    tabindex="-1"
    aria-labelledby="adminStudentSitInModalLabel"
    aria-hidden="true"
  >
    <div class="modal-dialog modal-dialog-centered" style="max-width: 720px; width: 95vw;">
      <div class="modal-content" style="border-radius: 14px;">
        <div class="modal-header">
          <h5 class="modal-title" id="adminStudentSitInModalLabel">Record Sit-in</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>

        <div class="modal-body">
          <div class="col-12">
            <label class="form-label fw-semibold">Student</label>
            <input
              id="adminStudentSitInModalStudentDisplay"
              type="text"
              class="form-control"
              value=""
              readonly
            />
          </div>

          <div
            id="adminStudentSitInModalActiveAlert"
            class="alert alert-warning py-2 mt-3 mb-3"
            style="display:none"
          >
            This student already has an active sit-in session.
          </div>

          <form id="adminStudentSitInModalTimeOutForm" action="/admin/student-sitin/time-out" method="POST" style="display:none">
            <input id="adminStudentSitInModalTimeOutStudentId" type="hidden" name="student_id" value="" />
            <input id="adminStudentSitInModalTimeOutReturnTo" type="hidden" name="returnTo" value="" />
            <button class="btn btn-danger w-100" type="submit">Time Out Student</button>
          </form>

          <form id="adminStudentSitInModalTimeInForm" action="/admin/student-sitin/time-in" method="POST" class="row g-3 mt-0" style="display:none">
            <input id="adminStudentSitInModalTimeInStudentId" type="hidden" name="student_id" value="" />
            <input id="adminStudentSitInModalTimeInReturnTo" type="hidden" name="returnTo" value="" />

            <div class="col-12 mt-3">
              <label class="form-label fw-semibold">Lab Room</label>
              <select name="lab_room" class="form-select" required>
                <option value="" disabled selected>Select laboratory</option>
                <option value="524">524</option>
                <option value="526">526</option>
                <option value="528">528</option>
                <option value="530">530</option>
                <option value="542">542</option>
                <option value="Mac">Mac</option>
              </select>
            </div>

            <div class="col-12">
              <label class="form-label fw-semibold">Purpose</label>
              <select name="purpose" class="form-select" required>
                <option value="" selected disabled>Select purpose</option>
                <option value="C#">C#</option>
                <option value="C">C</option>
                <option value="Java">Java</option>
                <option value="ASP.NET">ASP.NET</option>
                <option value="PHP">PHP</option>
                <option value="Python">Python</option>
                <option value="JavaScript">JavaScript</option>
                <option value="TypeScript">TypeScript</option>
                <option value="Networking">Networking</option>
              </select>
            </div>

            <div class="col-12">
              <button class="btn btn-primary w-100" type="submit">Record Time In</button>
            </div>
          </form>
