        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
        </div>
      </div>
    </div>
  </div>

  <script>
    (function () {
      var navLink = document.getElementById("adminStudentSearchNavLink");
      var form = document.getElementById("adminStudentSearchForm");
      var input = document.getElementById("adminStudentSearchInput");
      var resultsEl = document.getElementById("adminStudentSearchResults");
      var sitInModalEl = document.getElementById("adminStudentSitInModal");
      var searchModalEl = document.getElementById("adminStudentSearchModal");
      var sitInStudentDisplay = document.getElementById("adminStudentSitInModalStudentDisplay");
      var sitInActiveAlert = document.getElementById("adminStudentSitInModalActiveAlert");
      var timeInForm = document.getElementById("adminStudentSitInModalTimeInForm");
      var timeOutForm = document.getElementById("adminStudentSitInModalTimeOutForm");
      var timeInStudentId = document.getElementById("adminStudentSitInModalTimeInStudentId");
      var timeOutStudentId = document.getElementById("adminStudentSitInModalTimeOutStudentId");
      var timeInReturnTo = document.getElementById("adminStudentSitInModalTimeInReturnTo");
      var timeOutReturnTo = document.getElementById("adminStudentSitInModalTimeOutReturnTo");

      if (!navLink || !form || !input || !resultsEl) return;

      navLink.addEventListener("click", function (e) {
        // Prevent jumping to the top when href="#" is used.
        e.preventDefault();
      });

      function setResultsHtml(html) {
        resultsEl.innerHTML = html;
      }

      function escapeHtml(value) {
        return String(value ?? "").replace(/[&<>"']/g, function (ch) {
          if (ch === "&") return "&amp;";
          if (ch === "<") return "&lt;";
          if (ch === ">") return "&gt;";
          if (ch === '"') return "&quot;";
          return "&#39;";
        });
      }

      function renderResultsTable(results) {
        var rowsHtml = results
          .map(function (student) {
            var studentId = String(student.id || "").trim();
            var idNumber = String(student.id_number || "").trim();
            var fullName =
              String(student.first_name || "").trim() +
              " " +
              String(student.last_name || "").trim();
            var course = student.course || "-";
            var year = student.course_level || "-";
            var sessionsLeft =
              student.sessions_left === null || student.sessions_left === undefined
                ? 30
                : student.sessions_left;
            var hasActive = Number(student.active_sessions) > 0;
            var badgeClass = hasActive ? "bg-success" : "bg-secondary";
            var badgeLabel = hasActive ? "Active" : "Idle";

            return `
              <tr>
                <td class="text-nowrap">${escapeHtml(idNumber || "-")}</td>
                <td>${escapeHtml(fullName.trim() || "-")}</td>
                <td>${escapeHtml(course)}</td>
                <td class="text-center">${escapeHtml(year)}</td>
                <td class="text-center">${escapeHtml(sessionsLeft)}</td>
                <td class="text-center">
                  <span class="badge ${badgeClass}">${badgeLabel}</span>
                </td>
                <td class="text-center">
                  <button
                    class="btn btn-sm btn-primary"
                    type="button"
                    data-action="sit-in"
                    data-student-id="${escapeHtml(studentId)}"
                    data-id-number="${escapeHtml(idNumber)}"
                    data-first-name="${escapeHtml(String(student.first_name || "").trim())}"
                    data-last-name="${escapeHtml(String(student.last_name || "").trim())}"
                    data-active-sessions="${escapeHtml(Number(student.active_sessions || 0))}"
                    ${idNumber ? "" : "disabled"}
                  >
                    Sit-in
                  </button>
                </td>
              </tr>
            `;
          })
          .join("");

        var note =
          results.length >= 25
            ? '<div class="text-muted small mb-2">Showing up to 25 results. Refine your search to narrow it down.</div>'
            : '<div class="text-muted small mb-2">Select a student to sit-in.</div>';

        return `
          ${note}
          <div class="table-responsive">
            <table class="table table-bordered align-middle mb-0">
              <thead>
                <tr>
                  <th style="width: 120px;">ID Number</th>
                  <th style="width: 240px;">Student</th>
                  <th style="width: 100px;">Course</th>
                  <th style="width: 60px;" class="text-center">Year</th>
                  <th style="width: 90px;" class="text-center">Sessions</th>
                  <th style="width: 90px;" class="text-center">Status</th>
                  <th style="width: 90px;" class="text-center">Action</th>
                </tr>
              </thead>
              <tbody>
                ${rowsHtml}
              </tbody>
            </table>
          </div>
        `;
      }

      resultsEl.addEventListener("click", function (e) {
        var btn = e.target && e.target.closest
          ? e.target.closest('button[data-action="sit-in"]')
          : null;
        if (!btn) return;

        var studentId = String(btn.getAttribute("data-student-id") || "").trim();
        var idNumber = String(btn.getAttribute("data-id-number") || "").trim();
        var firstName = String(btn.getAttribute("data-first-name") || "").trim();
        var lastName = String(btn.getAttribute("data-last-name") || "").trim();
        var activeSessions = Number(btn.getAttribute("data-active-sessions") || 0);

        if (!studentId) {
          if (!idNumber) return;
          window.location.href =
            "/admin/student-sitin?q=" + encodeURIComponent(idNumber);
          return;
        }

        if (!window.bootstrap || !window.bootstrap.Modal || !sitInModalEl) {
          window.location.href =
            "/admin/student-sitin?q=" + encodeURIComponent(idNumber);
          return;
        }

        if (sitInStudentDisplay) {
          sitInStudentDisplay.value =
            (idNumber ? idNumber + " - " : "") + (firstName + " " + lastName).trim();
        }

        var returnTo = window.location.pathname + window.location.search;
        if (timeInForm && typeof timeInForm.reset === "function") {
          timeInForm.reset();
        }
        if (timeInStudentId) timeInStudentId.value = studentId;
        if (timeOutStudentId) timeOutStudentId.value = studentId;
        if (timeInReturnTo) timeInReturnTo.value = returnTo;
        if (timeOutReturnTo) timeOutReturnTo.value = returnTo;

        if (activeSessions > 0) {
          if (sitInActiveAlert) sitInActiveAlert.style.display = "block";
          if (timeOutForm) timeOutForm.style.display = "block";
          if (timeInForm) timeInForm.style.display = "none";
        } else {
          if (sitInActiveAlert) sitInActiveAlert.style.display = "none";
          if (timeOutForm) timeOutForm.style.display = "none";
          if (timeInForm) timeInForm.style.display = "block";
        }

        try {
          if (searchModalEl) {
            var searchModal = window.bootstrap.Modal.getInstance(searchModalEl);
            if (searchModal) searchModal.hide();
          }
        } catch (err) {}

        var sitInModal = window.bootstrap.Modal.getOrCreateInstance(sitInModalEl);
        sitInModal.show();
      });

      form.addEventListener("submit", async function (e) {
        e.preventDefault();

        var q = String(input.value || "").trim();
        if (!q) {
          setResultsHtml('<div class="alert alert-info mb-0">Enter a student ID number or name.</div>');
          return;
        }

        setResultsHtml(
          '<div class="d-flex align-items-center gap-2 text-muted"><div class="spinner-border spinner-border-sm" role="status"></div> Searching...</div>'
        );

        try {
          var resp = await fetch(
            "/admin/student-sitin/search?q=" + encodeURIComponent(q),
            { headers: { Accept: "application/json" } }
          );

          if (!resp.ok) {
            setResultsHtml('<div class="alert alert-danger mb-0">Unable to search students.</div>');
            return;
          }

          var payload = await resp.json();
          var results = (payload && payload.results) || [];

          if (!results.length) {
            setResultsHtml('<div class="alert alert-secondary mb-0">No matching student found.</div>');
            return;
          }

          setResultsHtml(renderResultsTable(results));
        } catch (err) {
          console.error(err);
          setResultsHtml('<div class="alert alert-danger mb-0">Unexpected error while searching.</div>');
        }
      });
    })();
  </script>
<% } %>
